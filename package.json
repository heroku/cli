{
  "name": "heroku",
  "description": "CLI to interact with Heroku",
  "version": "11.3.0-beta.0",
  "author": "Heroku",
  "bin": "./bin/run.js",
  "bugs": "https://github.com/heroku/cli/issues",
  "dependencies": {
