{
  "compilerOptions": {
    "allowJs": true, // required to support run-foreman.cjs and vendored foreman .cjs files in src/lib/local/foreman/
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "resolveJsonModule": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDirs": [
      "./src"
    ],
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "./src/**/*"
  ],
  "ts-node": {
    "esm": true
  }
}
