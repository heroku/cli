{
  "extension": [".ts"],
  "exclude": [
    "**/*.d.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "test/**/*",
    "dist/**/*",
    "lib/**/*",
    "coverage/**",
    ".nyc_output/**"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "reporter": [
    "text-summary",
    "html",
    "lcov"
  ],
  "statements": 60,
  "branches": 60,
  "functions": 60,
  "lines": 60
}
